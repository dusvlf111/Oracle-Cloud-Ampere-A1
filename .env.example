# 보안
APP_SECRET=                       # 32 bytes base64 — 세션 서명 + AES-256-GCM 키 도출 (필수)
# 관리자 계정은 env 가 아니라 최초 회원가입(POST /api/auth/setup)으로 DB(AppSetting)에 저장된다.
# (APP_USERNAME / APP_PASSWORD_HASH 는 제거됨 — PaaS env `$` 보간 문제 회피)
CORS_ORIGINS=http://localhost:3000
SESSION_SECURE=false              # HTTPS 배포 시 true (세션 쿠키 Secure 플래그)

# 프런트 (브라우저는 same-origin /api 만 사용, INTERNAL_API_URL 은 Next.js 서버만 봄)
INTERNAL_API_URL=http://server:8000

# 동시성
OCI_MAX_CONCURRENT=10             # 전역 동시 OCI 호출 상한
OCI_PER_CREDENTIAL_MAX=1          # 계정당 동시 호출 상한 (1 권장)

# 로깅
LOG_LEVEL=INFO
LOG_LEVEL_DB=INFO
LOG_RETENTION_DAYS=7
LOG_RETENTION_ROWS=10000

# 데이터베이스 (기본: SQLite — 컨테이너 /data 볼륨)
DATABASE_URL=sqlite:////data/app.db
KEYS_DIR=/data/keys               # OCI private key 저장 경로 (로컬 dev 는 ./data/keys)

# PostgreSQL 전환 (선택) — `docker compose --profile postgres up -d`
# 아래 DATABASE_URL 을 활성화하면 SQLite WAL 대신 커넥션 풀이 적용된다.
# DATABASE_URL=postgresql+psycopg://oci:oci@postgres:5432/oci
# POSTGRES_USER=oci
# POSTGRES_PASSWORD=oci
# POSTGRES_DB=oci
# DB_POOL_SIZE=5                   # 풀 기본 커넥션 수 (postgres 전용)
# DB_MAX_OVERFLOW=10               # 풀 초과 허용 커넥션 수
# DB_POOL_PRE_PING=true            # 끊긴 커넥션 자동 감지

# Redis 전환 (선택) — `docker compose --profile redis up -d`
# 설정 시 로그인 rate limit 저장소가 in-memory → Redis 로 전환된다 (미설정=in-memory).
# REDIS_URL=redis://redis:6379/0
